# ─── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3001

# ─── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=vehiculedz
DB_PASSWORD=vehiculedz_secret
DB_NAME=vehiculedz_db
DB_SYNC=true
DB_LOGGING=false

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ─── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Storage (S3 Compatible) ───────────────────────────────
STORAGE_DRIVER=local
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=vehiculedz-assets
S3_REGION=us-east-1
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_SIGNED_URL_EXPIRES=3600

# ─── SMS (Twilio / local provider) ────────────────────────
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Email ─────────────────────────────────────────────────
EMAIL_PROVIDER=mock
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@vehiculedz.dz

# ─── Firebase (Push Notifications) ────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Payment (Abstraction Layer) ──────────────────────────
PAYMENT_PROVIDER=mock
# CIB / Edahabia via SATIM
SATIM_MERCHANT_ID=
SATIM_TERMINAL_ID=
SATIM_USERNAME=
SATIM_PASSWORD=
SATIM_BASE_URL=https://satim.dz/payment/rest

# ─── Rate Limiting ─────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── OTP ───────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
